{
  "manifest_version": 3,
  "name": "Music Keeper",
  "version": "1.2.0",
  "description": "Tries to resume playback or skip to the next track on Apple Music and TIDAL.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://music.apple.com/*",
    "https://tidal.com/*",
    "https://listen.tidal.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Music Keeper"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.apple.com/*",
        "https://tidal.com/*",
        "https://listen.tidal.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
